{
  "name": "myavatar-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MyAvatar.ge Model Context Protocol server — the universal tool bus that exposes the produce/jobs/voice pipelines to any MCP client (Claude Code, Claude Desktop, automations).",
  "bin": { "myavatar-mcp-server": "dist/index.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
