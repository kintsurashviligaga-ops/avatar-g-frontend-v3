{
  "name": "avatar-g-workspace",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:cwd": "node scripts/check-workdir.mjs",
    "dev": "next dev -p 3000",
    "dev:3003": "next dev -p 3003",
    "clean": "node scripts/clean-next.mjs --all",
    "clean:next": "node scripts/clean-next.mjs --all",
    "clean:win": "powershell -ExecutionPolicy Bypass -File scripts/win-clean-next.ps1",
    "reinstall:win": "powershell -ExecutionPolicy Bypass -File scripts/win-reinstall.ps1",
    "build": "next build",
    "build:safe": "node scripts/build-safe.mjs",
    "build:clean": "node scripts/build-safe.mjs --clean",
    "vercel-build": "npm run build:clean",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest __tests__/lib/openai.test.ts __tests__/lib/agentg.personality.test.ts __tests__/lib/agentg.memory.test.ts __tests__/api/agent-g-chat.test.ts __tests__/api/agent-g-telegram-webhook.test.ts --runInBand",
    "test:enterprise": "jest __tests__/workflow/policy.test.ts __tests__/billing/plan-enforcement.test.ts __tests__/lib/monetization.enforcement.test.ts __tests__/lib/ai-router.test.ts __tests__/lib/tenant-isolation.test.ts __tests__/lib/rate-limit-window.test.ts __tests__/lib/metering-aggregation.test.ts __tests__/api/billing-usage-route.test.ts __tests__/api/agent-g-router-execute-route.test.ts __tests__/api/org-branding-route.test.ts --runInBand",
    "load:test": "npx tsx scripts/load-test.ts",
    "verify:production": "npx tsx scripts/verify-production.ts",
    "test:telegram:webhook": "powershell -ExecutionPolicy Bypass -File scripts/telegram-webhook-smoke.ps1",
    "test:webhooks": "node scripts/test-webhooks.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.983.0",
