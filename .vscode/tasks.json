{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-prod-check",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "validate-typecheck",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"typecheck"
			],
			"isBackground": false
		},
		{
			"label": "validate-build-2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "validate-dev-run",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "final-typecheck",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"typecheck"
			],
			"isBackground": false
		},
		{
			"label": "final-build",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "final-typecheck-2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"typecheck"
			],
			"isBackground": false
		},
		{
			"label": "final-build-2",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "validate-tests-now",
			"type": "shell",
			"command": "npm",
			"args": [
				"test",
				"--",
				"--runInBand"
			],
			"isBackground": false
		},
		{
			"label": "validate-test-unit",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:unit"
			],
			"isBackground": false
		},
		{
			"label": "validate-tests-json",
			"type": "shell",
			"command": "npm",
			"args": [
				"test",
				"--",
				"--runInBand",
				"--json",
				"--outputFile",
				"jest-results.json"
			],
			"isBackground": false
		},
		{
			"label": "install-test-react",
			"type": "shell",
			"command": "npm",
			"args": [
				"install",
				"-D",
				"@testing-library/react"
			],
			"isBackground": false
		},
		{
			"label": "validate-revenue-no-cache",
			"type": "shell",
			"command": "npx",
			"args": [
				"jest",
				"__tests__/revenue-optimization/revenuOptimization.test.ts",
				"--runInBand",
				"--no-cache"
			],
			"isBackground": false
		},
		{
			"label": "enterprise-policy-tests",
			"type": "shell",
			"command": "npx",
			"args": [
				"jest",
				"__tests__/workflow/policy.test.ts",
				"__tests__/billing/plan-enforcement.test.ts",
				"--runInBand"
			],
			"isBackground": false
		},
		{
			"label": "cert-typecheck",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
