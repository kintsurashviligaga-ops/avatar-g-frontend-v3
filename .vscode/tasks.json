				"--runInBand"
			],
			"isBackground": false
		},
		{
			"label": "cert-typecheck",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"typecheck"
			],
			"isBackground": false
		},
		{
			"label": "cert-enterprise-tests",
			"type": "shell",
			"command": "npx",
			"args": [
				"jest",
				"__tests__/workflow/policy.test.ts",
				"__tests__/billing/plan-enforcement.test.ts",
