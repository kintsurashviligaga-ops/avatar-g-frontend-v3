# Myavatar.ge environment template
# Copy to .env.local for local development.

# ------------------------------
# Core app and Supabase
# ------------------------------
# Required for most authenticated/data-backed workflows.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# ------------------------------
# Base URL (set at least one)
# ------------------------------
# Preferred public base URL used by links/metadata.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Server-side fallback base URL if NEXT_PUBLIC_BASE_URL is not set.
BASE_URL=http://localhost:3000

# Optional legacy URL aliases used by older modules.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_PHONE_AUTH_ENABLED=false
NEXT_PUBLIC_FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_PENTAGON_API_URL=

# ------------------------------
# Stripe (required only when Stripe is enabled/used)
# ------------------------------
# Set ENABLE_STRIPE=true to enforce Stripe requirements.
ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# ------------------------------
# Optional production hardening
# ------------------------------
# Comma-separated origins for API CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional monitoring/analytics.
SENTRY_DSN=
VERCEL_ANALYTICS_ID=

# ------------------------------
# Optional AI/storage providers
# ------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
