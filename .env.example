# Myavatar.ge environment template
# Copy to .env.local for local development.

# ------------------------------
# Core app and Supabase
# ------------------------------
# Required for most authenticated/data-backed workflows.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# ------------------------------
# Base URL (set at least one)
# ------------------------------
# Preferred public base URL used by links/metadata.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Server-side fallback base URL if NEXT_PUBLIC_BASE_URL is not set.
BASE_URL=http://localhost:3000

# Optional legacy URL aliases used by older modules.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_PHONE_AUTH_ENABLED=false
NEXT_PUBLIC_FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_PENTAGON_API_URL=

# ------------------------------
# Stripe (required only when Stripe is enabled/used)
# ------------------------------
# Set ENABLE_STRIPE=true to enforce Stripe requirements.
ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# ------------------------------
# Optional production hardening
# ------------------------------
# Comma-separated origins for API CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional monitoring/analytics.
SENTRY_DSN=
VERCEL_ANALYTICS_ID=

# ------------------------------
# Optional AI/storage providers
# ------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=claude-opus-4.6-fast
PROVIDER_MODE=real
DEEPSEEK_API_KEY=
GROQ_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
NANOBANANA_API_KEY=
# Optional: direct endpoint URL (if set, overrides base/path composition)
NANOBANANA_API_URL=
# Optional: base URL + endpoint-specific paths
NANOBANANA_API_BASE_URL=https://api.nanobananaapi.ai
# Optional endpoint overrides (defaults to /v1/generate)
NANOBANANA_PATH_TASK_DETAILS=
NANOBANANA_PATH_TEXT_TO_IMAGE=
NANOBANANA_PATH_PRO_1K2K=
NANOBANANA_PATH_PRO_4K=
NANOBANANA_PATH_V2_1K=
NANOBANANA_PATH_V2_2K=
NANOBANANA_PATH_V2_4K=
UDIO_API_KEY=
# Base URL for Udio API (supports https://udioapi.pro and compatible gateways)
UDIO_API_URL=https://udioapi.pro
# Optional path overrides
UDIO_GENERATE_PATH=/api/v2/generate
UDIO_FEED_PATH=/api/v2/feed
UDIO_MODEL=chirp-v4-5
UDIO_POLL_INTERVAL_MS=5000
UDIO_MAX_POLL_ATTEMPTS=40
WORLDLABS_API_KEY=
WORLDLABS_API_URL=https://api.worldlabs.ai/v1/worlds/generate
WORLDLABS_LOW_CREDITS_THRESHOLD=300
WORLDLABS_ADMIN_ALERT_WEBHOOK_URL=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_GEORGIAN_VOICE_ID=

VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Realtime V2V voice (websocket + low-latency providers)
VOICE_V2V_WS_URL=ws://localhost:8787/realtime
NEXT_PUBLIC_VOICE_V2V_WS_URL=ws://localhost:8787/realtime
VOICE_V2V_WS_TOKEN_SECRET=
VOICE_V2V_STT_PROVIDER=openai
VOICE_V2V_TTS_PROVIDER=elevenlabs
VOICE_V2V_STT_MODEL=gpt-4o-mini-transcribe
VOICE_V2V_LLM_MODEL=gpt-4o-mini
VOICE_V2V_DEEPGRAM_MODEL=nova-2
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
